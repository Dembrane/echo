default_platform(:ios)

platform :ios do
  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    key_id = ENV.fetch("ASC_KEY_ID")
    issuer_id = ENV.fetch("ASC_ISSUER_ID")
    key_path = File.expand_path("AuthKey.p8", __dir__)

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_path
    )

    # Pass the ASC API key to xcodebuild so `-allowProvisioningUpdates` can
    # authenticate headlessly and create the Distribution cert + app-store
    # profile (this Mac otherwise only has an Apple Development cert).
    build_app(
      project: "DembraneGo.xcodeproj",
      scheme: "DembraneGo",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyID #{key_id} " \
              "-authenticationKeyIssuerID #{issuer_id} " \
              "-authenticationKeyPath #{key_path}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
