{% layout "email-base" %} {% block content %}

<h1>Reset your password.</h1>

<p>
  We got a request to set a new password for your dembrane account. The link expires in 24 hours.
</p>

<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 24px;">
  <tr><td>
    <a class="button" rel="noopener" target="_blank" href="{{url}}">Reset password</a>
  </td></tr>
</table>

<p style="font-size:13px; line-height:1.65; margin:0 0 28px; color:#2D2D2C;">
  Or paste this into your browser:<br />
  <span style="color:#4169E1; word-break:break-all;">{{url}}</span>
</p>

<p style="font-size:15px; line-height:1.65; margin:0 0 28px;">
  Didn't request this? Ignore this email — your password stays as it is.
</p>

{% endblock %}
