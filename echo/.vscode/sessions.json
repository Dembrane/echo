{
    "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
    "active": "default",
    "keepExistingTerminals": false,
    "sessions": {
        "default": [
            {
                "autoExecuteCommands": true,
                "commands": [
                    "cd server",
                    "./run.sh"
                ],
                "icon": "server",
                "name": "server"
            },
            [
                {
                    "autoExecuteCommands": true,
                    "commands": [
                        "cd server",
                        "./run-worker.sh"
                    ],
                    "icon": "gear",
                    "name": "workers"
                },
                {
                    "autoExecuteCommands": true,
                    "commands": [
                        "cd server",
                        "./run-worker-cpu.sh"
                    ],
                    "icon": "gear",
                    "name": "workers-cpu"
                },
                {
                    "autoExecuteCommands": true,
                    "commands": [
                        "cd server",
                        "./run-scheduler.sh"
                    ],
                    "icon": "clock",
                    "name": "scheduler"
                }
            ],
            [
                {
                    "autoExecuteCommands": true,
                    "commands": [
                        "cd frontend",
                        "pnpm run dev"
                    ],
                    "icon": "browser",
                    "name": "admin-dashboard"
                },
                {
                    "autoExecuteCommands": true,
                    "commands": [
                        "cd frontend",
                        "pnpm run participant:dev"
                    ],
                    "icon": "browser",
                    "name": "participant-portal"
                }
            ]
        ]
    },
    "theme": "tribe"
}