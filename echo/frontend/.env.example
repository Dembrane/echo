# No env vars are required — not locally and not on Vercel.
#
# All config (base URLs, feature flags, PostHog) is resolved in code per
# environment: src/config.ts detects production / next / testing / local from
# the hostname and resolves values via byEnv(). Everything there is public
# anyway, so it lives in plain code instead of Vercel env vars.
#
# The VITE_* overrides below are escape hatches only; create a .env with one
# of them if you need to point at a non-standard backend.

# Base URL overrides (defaults: same-origin Vite proxy locally, the
# *.dembrane.com hosts for deployed environments)
# VITE_API_BASE_URL=
# VITE_ADMIN_BASE_URL=
# VITE_PARTICIPANT_BASE_URL=
# VITE_DIRECTUS_PUBLIC_URL=

# Set to "1" to enable. The participant router also auto-enables on portal.*
# hostnames; pnpm participant:dev sets it for local dev.
# VITE_DEBUG_MODE=1
# VITE_USE_PARTICIPANT_ROUTER=1

# Agentation overlay: rendering is gated at runtime (ENABLE_AGENTATION in
# src/config.ts, off in production). Set "0" to also strip the JSX source
# metadata from a build.
# VITE_ENABLE_AGENTATION=0

# Community Slack invite URL (override if the link expires).
# VITE_COMMUNITY_SLACK_URL=https://join.slack.com/t/dembranecommunity/shared_invite/...
